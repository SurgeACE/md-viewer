{
  "appId": "com.mdview.app",
  "appName": "MDView",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0a0a"
    },
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#0a0a0a",
      "androidSplashResourceName": "splash",
      "showSpinner": false,
      "launchFadeOutDuration": 300
    }
  },
  "android": {
    "buildOptions": {
      "keystorePath": "",
      "keystoreAlias": ""
    },
    "allowMixedContent": false
  }
}
